package com.example.demo.client;

import com.example.demo.dto.ProxyRequest;
import com.example.demo.service.TokenService;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.http.*;
import org.springframework.stereotype.Component;
import org.springframework.web.client.RestTemplate;

import java.util.Map;

@Component
public class ThirdPartyClient {

    private final RestTemplate restTemplate;
    private final TokenService tokenService;

    @Value("${thirdparty.base-url}")
    private String baseUrl;

    public ThirdPartyClient(RestTemplate restTemplate, TokenService tokenService) {
        this.restTemplate = restTemplate;
        this.tokenService = tokenService;
    }

    public Map<String, Object> callThirdParty(ProxyRequest request) {

        String token = tokenService.getToken();

        HttpHeaders headers = new HttpHeaders();
        headers.setBearerAuth(token);
        headers.setContentType(MediaType.APPLICATION_JSON);

        // Add custom headers from client
        if (request.getHeaders() != null) {
            request.getHeaders().forEach((k, v) -> headers.add(k, String.valueOf(v)));
        }

        HttpEntity<Object> entity = new HttpEntity<>(request.getBody(), headers);

        String finalUrl = baseUrl + request.getUrl();

        HttpMethod method = HttpMethod.valueOf(request.getMethod().toUpperCase());

        ResponseEntity<Map> response = restTemplate.exchange(
                finalUrl,
                method,
                entity,
                Map.class
        );

        return response.getBody();
    }
}

import java.io.IOException;
import java.nio.file.*;
import java.util.stream.Stream;

public class FolderComparator {

    public static void compareFolders(Path folder1, Path folder2) throws IOException {

        try (Stream<Path> files = Files.list(folder1)) {
            files
                .filter(Files::isRegularFile)
                .forEach(file1 -> {
                    try {
                        String originalName = file1.getFileName().toString();
                        String modifiedName = manipulateFileName(originalName);

                        // Search in folder2
                        try (Stream<Path> folder2Files = Files.list(folder2)) {
                            folder2Files
                                .filter(Files::isRegularFile)
                                .filter(file2 -> file2.getFileName().toString().startsWith(modifiedName))
                                .forEach(file2 -> {
                                    try {
                                        long lineCount = Files.lines(file2).count();

                                        if (lineCount > 1) {
                                            System.out.println("Match found:");
                                            System.out.println("Folder1 File: " + file1);
                                            System.out.println("Folder2 File: " + file2);
                                            System.out.println("Line Count: " + lineCount);
                                            System.out.println("---------------------------");
                                        }

                                    } catch (IOException e) {
                                        e.printStackTrace();
                                    }
                                });
                        }

                    } catch (IOException e) {
                        e.printStackTrace();
                    }
                });
        }
    }

    /**
     * Placeholder function to manipulate file name.
     * Modify this as per your requirement.
     */
    private static String manipulateFileName(String fileName) {
        // Example: remove extension
        int dotIndex = fileName.lastIndexOf('.');
        if (dotIndex > 0) {
            return fileName.substring(0, dotIndex);
        }
        return fileName;

        // You can customize:
        // return fileName.replace("_old", "");
        // return fileName.substring(0, 5);
    }

    public static void main(String[] args) throws IOException {
        Path folder1 = Paths.get("C:/folder1");
        Path folder2 = Paths.get("C:/folder2");

        compareFolders(folder1, folder2);
    }
}

public ResponseEntity<String> callApi(String className, String jsonString, String url) throws Exception {

    // Step 1: Load class
    Class<?> clazz = Class.forName(className);

    // Step 2: Convert JSON → List<clazz>
    ObjectMapper objectMapper = new ObjectMapper();
    JavaType type = objectMapper.getTypeFactory()
            .constructCollectionType(List.class, clazz);

    List<?> list = objectMapper.readValue(jsonString, type);

    // Step 3: Call API
    RestTemplate restTemplate = new RestTemplate();

    HttpHeaders headers = new HttpHeaders();
    headers.setContentType(MediaType.APPLICATION_JSON);

    HttpEntity<List<?>> request = new HttpEntity<>(list, headers);

    return restTemplate.exchange(url, HttpMethod.POST, request, String.class);
}

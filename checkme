package com.example.demo.service;

import com.example.demo.client.ThirdPartyClient;
import com.example.demo.dto.ProxyRequest;
import org.springframework.stereotype.Service;

import java.util.Map;

@Service
public class ProxyService {

    private final ThirdPartyClient client;

    public ProxyService(ThirdPartyClient client) {
        this.client = client;
    }

    public Map<String, Object> process(ProxyRequest request) {
        return client.callThirdParty(request);
    }
}

Map<String, List<Person>> result =
    persons.stream()
           .collect(Collectors.groupingBy(
               Person::getDepartment,
               Collectors.collectingAndThen(
                   Collectors.toList(),
                   list -> list.stream()
                               .sorted(Comparator.comparing(Person::getAge))
                               .collect(Collectors.toList())
               )
           ));
